#, python-format
msgid ""
"Ticket price: %(price)s EUR. You will be redirected to checkout after "
"registration."
msgstr ""
"Ticketpreis: %(price)s EUR. Du wirst nach der Registrierung zum Checkout "
"weitergeleitet."

msgid ""
"This is a free ticket. You will receive your ticket by e-mail after "
"registration."
msgstr ""
"Dies ist ein Gratis-Ticket. Du erhaeltst dein Ticket nach der "
"Registrierung per E-Mail."

msgid "Register"
msgstr "Registrieren"

msgid "Register & proceed to checkout"
msgstr "Registrieren & zum Checkout"

