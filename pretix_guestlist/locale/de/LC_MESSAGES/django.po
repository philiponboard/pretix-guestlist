msgid "Guest List"
msgstr "Gaesteliste"

msgid ""
"Smart guest list management for DJs and artists. Assign individual guest "
"list quotas and let guests self-register."
msgstr ""
"Gaestelisten-Verwaltung fuer DJs und Kuenstler. Individuelle Kontingente "
"zuweisen und Gaeste sich selbst registrieren lassen."

msgid "Guest List (CSV)"
msgstr "Gaesteliste (CSV)"

msgid "DJ"
msgstr "DJ"

msgid "First name"
msgstr "Vorname"

msgid "Last name"
msgstr "Nachname"

msgid "E-Mail"
msgstr "E-Mail"

msgid "Ticket type"
msgstr "Ticket-Typ"

msgid "Status"
msgstr "Status"

msgid "Registered"
msgstr "Registriert"

msgid "Order"
msgstr "Bestellung"

msgid "Voucher code"
msgstr "Gutscheincode"

msgid "Full Price Product"
msgstr "Vollpreis-Produkt"

msgid "Half Price Product"
msgstr "Halber-Preis-Produkt"

msgid "Free Product"
msgstr "Gratis-Produkt"

msgid "guest@example.com"
msgstr "gast@example.com"

msgid "Hide products from shop"
msgstr "Produkte im Shop verstecken"

msgid ""
"Automatically hide guest list products from the normal shop. Guests can only "
"access them via their personal link."
msgstr ""
"Gaesteliste-Produkte automatisch im normalen Shop verstecken. Gaeste koennen "
"sie nur ueber ihren persoenlichen Link erreichen."

msgid "Send reminder emails"
msgstr "Erinnerungsmails senden"

msgid ""
"Automatically send reminder emails to guests who have not registered yet (7 "
"days and 2 days before the event)."
msgstr ""
"Automatisch Erinnerungsmails an Gaeste senden, die sich noch nicht "
"registriert haben (7 Tage und 2 Tage vor dem Event)."

#, python-brace-format
msgid "Your guest list for {event_name}"
msgstr "Deine Gaesteliste fuer {event_name}"

msgid "E-Mail subject"
msgstr "E-Mail-Betreff"

#, python-brace-format
msgid ""
"Hello {dj_name},\n"
"\n"
"you have {quota} half-price guest list spots for {event_name}.\n"
"\n"
"Share this link with your guests:\n"
"{link}\n"
"\n"
"Your guests can register themselves and will receive their ticket via e-"
"mail.\n"
"\n"
"Best regards,\n"
"The {event_name} Team"
msgstr ""
"Hallo {dj_name},\n"
"\n"
"du hast {quota} Half-Price-Plaetze auf der Gaesteliste fuer {event_name}.\n"
"\n"
"Teile diesen Link mit deinen Gaesten:\n"
"{link}\n"
"\n"
"Deine Gaeste koennen sich selbst registrieren und erhalten ihr Ticket per "
"E-Mail.\n"
"\n"
"Viele Gruesse,\n"
"Das {event_name} Team"

msgid "E-Mail template"
msgstr "E-Mail-Vorlage"

msgid "Registration page text"
msgstr "Text auf der Registrierungsseite"

msgid "Guest list settings"
msgstr "Gaesteliste-Einstellungen"

msgid "Name"
msgstr "Name"

msgid "Half-Price Quota"
msgstr "Half-Price-Kontingent"

msgid "Free Quota"
msgstr "Free-Kontingent"

msgid "Token"
msgstr "Token"

msgid "Invitation sent"
msgstr "Einladung gesendet"

msgid "Invitation sent at"
msgstr "Einladung gesendet am"

msgid "Notes"
msgstr "Notizen"

msgid "Created"
msgstr "Erstellt"

msgid "DJs"
msgstr "DJs"

msgid "Full Price"
msgstr "Vollpreis"

msgid "Half Price"
msgstr "Halber Preis"

msgid "Free"
msgstr "Gratis"

msgid "Invited"
msgstr "Eingeladen"

msgid "Checked in"
msgstr "Eingecheckt"

msgid "Guest token"
msgstr "Gast-Token"

msgid "Voucher"
msgstr "Gutschein"

msgid "Reminders sent"
msgstr "Erinnerungen gesendet"

msgid "Registered at"
msgstr "Registriert am"

msgid "Guest"
msgstr "Gast"

msgid "Guests"
msgstr "Gaeste"

msgid "Guest list voucher for {}"
msgstr "Gaesteliste-Gutschein fuer {}"

msgid "Half-price quota exhausted."
msgstr "Half-Price-Kontingent erschoepft."

msgid "Free ticket quota exhausted."
msgstr "Free-Ticket-Kontingent erschoepft."

msgid "No product configured for this ticket type."
msgstr "Kein Produkt fuer diesen Ticket-Typ konfiguriert."

msgid "Scan this QR code to open your guest list dashboard."
msgstr "Scanne diesen QR-Code um dein Gaesteliste-Dashboard zu oeffnen."

#, python-brace-format
msgid "You are on the guest list for {event_name}"
msgstr "Du stehst auf der Gaesteliste fuer {event_name}"

#, python-brace-format
msgid ""
"Hello,\n"
"\n"
"{dj_name} has put you on the guest list for {event_name}.\n"
"Ticket type: {ticket_type}\n"
"\n"
"Please complete your registration here:\n"
"{link}\n"
"\n"
"Best regards,\n"
"The {event_name} Team"
msgstr ""
"Hallo,\n"
"\n"
"{dj_name} hat dich auf die Gaesteliste fuer {event_name} gesetzt.\n"
"Ticket-Typ: {ticket_type}\n"
"\n"
"Bitte schliesse deine Registrierung hier ab:\n"
"{link}\n"
"\n"
"Viele Gruesse,\n"
"Das {event_name} Team"

#, python-brace-format
msgid "Reminder: You are on the guest list for {event_name}"
msgstr "Erinnerung: Du stehst auf der Gaesteliste fuer {event_name}"

#, python-brace-format
msgid ""
"Hello,\n"
"\n"
"This is a friendly reminder that {dj_name} has put you on the guest list for "
"{event_name}, but you have not yet completed your registration.\n"
"\n"
"Ticket type: {ticket_type}\n"
"\n"
"Please complete your registration here:\n"
"{link}\n"
"\n"
"Best regards,\n"
"The {event_name} Team"
msgstr ""
"Hallo,\n"
"\n"
"dies ist eine freundliche Erinnerung, dass {dj_name} dich auf die "
"Gaesteliste fuer {event_name} gesetzt hat. Du hast deine Registrierung "
"noch nicht abgeschlossen.\n"
"\n"
"Ticket-Typ: {ticket_type}\n"
"\n"
"Bitte schliesse deine Registrierung hier ab:\n"
"{link}\n"
"\n"
"Viele Gruesse,\n"
"Das {event_name} Team"

msgid "Already registered"
msgstr "Bereits registriert"

msgid ""
"You have already completed your registration. Check your e-mail for your "
"ticket."
msgstr ""
"Du hast deine Registrierung bereits abgeschlossen. Pruefe deine E-Mail "
"fuer dein Ticket."

